table><table schema="main" name="UserChat" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="48"/><column index="3" value="47"/><column index="4" value="55"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE &quot;Contact&quot; (
	&quot;Id&quot;	INTEGER NOT NULL,
	&quot;UserId1&quot;	INTEGER NOT NULL,
	&quot;UserId2&quot;	INTEGER NOT NULL,
	&quot;createAt&quot;	TEXT,
	&quot;chatId&quot;	INTEGER NOT NULL,
	UNIQUE(UserId1, UserId2),
	PRIMARY KEY(&quot;Id&quot; AUTOINCREMENT),
	FOREIGN KEY(&quot;UserId1&quot;) REFERENCES &quot;Users&quot;(&quot;Id&quot;),
	FOREIGN KEY(&quot;UserId2&quot;) REFERENCES &quot;Users&quot;(&quot;Id&quot;),
	FOREIGN KEY(&quot;chatId&quot;) REFERENCES &quot;Chats&quot;(&quot;Id&quot;)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
