<Window x:Class="RestApi.Contacts"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestApi"
        mc:Ignorable="d"
        Title="Contacts" Height="600" Width="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400">

            </ColumnDefinition>
            <ColumnDefinition>
            </ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition ></RowDefinition>
        </Grid.RowDefinitions>




        <Rectangle  Grid.ColumnSpan="2" Width="auto" Height="50" Fill="#FF6CBEE8" ></Rectangle>
        <Button x:Name="buttonPanel" Grid.Column="0" Width="60" Height="40" Margin="0,0,350,0" Click="Button_Click" >
            <Button.Background>
                <ImageBrush ImageSource="/ButtonPanel.png"/>
            </Button.Background>
        </Button>

        <ListBox x:Name="BoxContact" Grid.Row="1" SelectionChanged="BoxContact_SelectionChanged"></ListBox>
        <Label x:Name="UserName" Grid.Column="1" Content="b"></Label>
        <ContentControl x:Name="ChatDisplay" Grid.Column="1" Grid.Row="1" ></ContentControl>
        <ContentControl x:Name="Panel" Grid.Column="0" Grid.Row="1"  ></ContentControl>
    </Grid>
</Window>
