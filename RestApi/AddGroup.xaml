<Page x:Class="RestApi.AddGroup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RestApi"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddGroup"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition ></RowDefinition>
            <RowDefinition ></RowDefinition>
            <RowDefinition ></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Label Content="Создать группу" Grid.Row="0" Grid.ColumnSpan="2" Background="#FF0AE3FF"></Label>
        <TextBox x:Name="NameGroup" Grid.Row="0" Grid.ColumnSpan="2" Margin="60,75,60,45" />
        <TextBlock Text="Придумайте название группы..." IsHitTestVisible="False" Foreground="Gray" Margin="60,77,0,45"   >
            <TextBlock.Style >
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Text, ElementName=search}" Value="">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBox x:Name="search" Grid.Row="0" Grid.ColumnSpan="2" Margin="60,110,60,10" />
        <TextBlock Text="Введите друга..." IsHitTestVisible="False" Foreground="Gray" Margin="60,110,43,10"  >
            <TextBlock.Style >
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Text, ElementName=search}" Value="">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <Button Grid.Column="0" Grid.Row="2" Height="auto"  Margin="0,98,0,0" Content="Выйти"  Background="#FF0AE3FF" Click="Button_Click"></Button>
        <Button x:Name="accept" Grid.Column="1" Grid.Row="2" Height="auto" Grid.ColumnSpan="2" Margin="0,98,0,0" Content="Принять"  Background="#FF0AE3FF"></Button>
        <ListBox x:Name="ListUsers" Grid.Row="1" Grid.ColumnSpan="2" Height="auto" Width="auto"></ListBox>
    </Grid>
</Page>
