<Window x:Class="RestApi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestApi"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
            <Label x:Name="output"></Label>
            <Button x:Name="click" Grid.Row="3" Click="click_Click" Content="Отправить на сервер"/>
        <TextBox x:Name="inputName" Grid.Column="0" Grid.Row="0"></TextBox>
        <TextBox x:Name="inputPassword" Grid.Column="0" Grid.Row="1"></TextBox>
    </Grid>
</Window>
