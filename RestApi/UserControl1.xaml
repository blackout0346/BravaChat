<UserControl x:Class="RestApi.UserControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestApi"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="#FFFFFF">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*">
            </RowDefinition>
            <RowDefinition>
            </RowDefinition>
        </Grid.RowDefinitions>
        <ListBox x:Name="MessagesList" Grid.Row="0" Grid.RowSpan="2" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,50">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding msg}" FontSize="14" TextWrapping="Wrap" Foreground="Black" ></TextBlock>
                        <TextBlock Text="{Binding senddate}" FontSize="10" TextWrapping="Wrap" Foreground="Black" ></TextBlock>
                        <TextBlock Text="{Binding login}" FontSize="10" TextWrapping="Wrap" Foreground="Black" ></TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBox  SpellCheck.IsEnabled="True" Language="ru-ru" x:Name="InputMsg" Grid.Row="1" Background="#80C8ED" Width="700" Height="50" Margin="0,175,100,0"  ></TextBox>
        <Button x:Name="sendMessage" Grid.Row="1"  Width="50" Height="50" Margin="724,175,26,0" Content="Send" Click="sendMessage_Click" Background="White" Focusable="False" FontFamily="Segoe UI Variable Text Semibold" FontSize="14" />

    </Grid>
</UserControl>
