<Window x:Class="RestApi.authification"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestApi"
        mc:Ignorable="d"
             MinHeight="400"
             MinWidth="400"
             MaxHeight="500"
             MaxWidth="500"
        Title="authification" Height="400" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition ></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Label Content="Регистрация" FontSize="20"  FontFamily="Century Gothic" Margin="10" Grid.Row="0" Width="140" FontWeight="Heavy" Grid.ColumnSpan="2"/>
        <Label Content="Имя" FontStyle="Italic" Margin="0,45,0,9" Grid.RowSpan="2" />
        <Label Content="Пароль" Grid.Row="1" FontStyle="Italic" Margin="0,56,0,9" Grid.RowSpan="2" ></Label>
        <Label Content="Номер телефона" Grid.Row="2" FontStyle="Italic" Margin="0,57,0,10" Grid.RowSpan="2" ></Label>
        <Label Content="Почта" Grid.Row="3" FontStyle="Italic" Margin="0,56,0,10" Grid.RowSpan="2" ></Label>
        <TextBox x:Name="inputName" Grid.Column="0" Grid.Row="1" Margin="18" Grid.ColumnSpan="2"/>
        <TextBox x:Name="inputPassword" Grid.Column="0" Grid.Row="2" Margin="18" Grid.ColumnSpan="2" />
        <TextBox x:Name="inputNumber" Grid.Column="0" Grid.Row="3" Margin="18" Grid.ColumnSpan="2"/>
        <TextBox x:Name="inputEmail" Grid.Column="0" Grid.Row="4" Margin="18" Grid.ColumnSpan="2" />
        <Button x:Name="click" Grid.Row="5" Grid.Column="1" Click="click_Click" Content="Зарегистрироваться" Background="#FF0AE3FF" Grid.RowSpan="4"  />
        <Button x:Name="close" Grid.Row="5"  Click="close_Click" Content="Выйти"  Background="#FF0AE3FF" Grid.RowSpan="2"  />
    </Grid>
</Window>
